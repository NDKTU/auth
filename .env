POSTGRES_USER=auth_user
POSTGRES_PASSWORD=auth_password
POSTGRES_DB=auth_db
POSTGRES_HOST=db
POSTGRES_PORT=5432

DATABASE__URL=postgresql+asyncpg://auth_user:auth_password@localhost:5432/auth_db
DATABASE__ECHO=false
DATABASE__ECHO_POOL=false
DATABASE__POOL_SIZE=5
DATABASE__MAX_OVERFLOW=10

AUTH__SECRET_KEY=super-secret-key-change-in-production
AUTH__ALGORITHM=HS256
AUTH__ACCESS_TOKEN_EXPIRE_MINUTES=60
